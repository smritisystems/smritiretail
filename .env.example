# SMRITI Retail OS AI Intelligence Credentials
# Get your Gemini API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=

# Platform Abstraction Layer (PAL) Provider Options
DATABASE_PROVIDER=postgres
SYNC_PROVIDER=postgres
CACHE_PROVIDER=memory
STORAGE_PROVIDER=filesystem

# PostgreSQL Standalone Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smriti_retail_db
POSTGRES_PORT=5432

# Docker-Compose Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=smriti_retail_db

# Local development / test environment values
ENVIRONMENT=development
JWT_SECRET_KEY=CHANGE_ME_FOR_DEVELOPMENT_ONLY_JWT

# SGIP Vault Master Key (AES-256-GCM + HKDF-SHA256 Root Key)
# MUST be generated fresh per environment (never copied from example to production)
# MUST NOT be the same value as JWT_SECRET_KEY
SGIP_VAULT_MASTER_KEY=CHANGE_ME_FOR_DEVELOPMENT_ONLY_VAULT

# Internal Service-to-Service Authentication Key
# REQUIRED — the backend will refuse to start if this is missing
# MUST be a random string distinct from JWT_SECRET_KEY and SGIP_VAULT_MASTER_KEY
INTERNAL_SERVICE_KEY=CHANGE_ME_FOR_DEVELOPMENT_ONLY_INTERNAL
